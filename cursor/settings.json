{
  // Avoid loading powershell profile during terminal invocations
  "terminal.integrated.automationProfile.windows": {
    "path": "${env:windir}\\System32\\WindowsPowerShell\\v1.0\\powershell.exe",
    "args": ["-NoProfile"]
  },
  // Neovim setting tweaks
  "vscode-neovim.neovimExecutablePaths.linux": "/snap/nvim/current/usr/bin/nvim",
  "vscode-neovim.neovimInitVimPaths.linux": "/home/desmond/.config/nvim/init.vim",
  "vscode-neovim.compositeKeys": {
    "jk": {
      "command": "vscode-neovim.escape"
    }
  },
  "extensions.experimental.affinity": {
    "asvetliakov.vscode-neovim": 1
  },
  // Adds prettier
 "[typescript]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode"
  },
  "[typescriptreact]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode"
  },
  // Misc
  "remote.SSH.remotePlatform": {
    "archeplex": "linux"
  },
  "workbench.editor.enablePreview": false,
  "window.autoDetectColorScheme": false,
  "editor.rulers": [
    100
  ],
 
}
