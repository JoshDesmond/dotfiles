# Dotfiles git configuration.

[user]
	name = Josh Desmond
	email = JoshDesmond@users.noreply.github.com
	signingkey = ~/.ssh/id_rsa.pub

[core]
	editor = nvim

[init]
	defaultBranch = main

[commit]
	gpgsign = true

[gpg]
	format = ssh

[pull]
	rebase = true

[fetch]
	prune = true

[push]
	autoSetupRemote = true
